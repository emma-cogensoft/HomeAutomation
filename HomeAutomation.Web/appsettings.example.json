{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "CloudInverterApiSettingsOptions": {
      // Solax cloud API URL with your token ID and inverter serial number.
      // Format: https://www.solaxcloud.com/proxyApp/proxy/api/{REQUESTNAME}.do?tokenId=YOUR_TOKEN&sn=YOUR_SERIAL
      "RequestTemplateUri": "https://www.solaxcloud.com/proxyApp/proxy/api/{REQUESTNAME}.do?tokenId=YOUR_TOKEN_ID&sn=YOUR_SERIAL_NUMBER"
    },
    "LocalInverterApiSettingsOptions": {
      // LAN IP address of your inverter (e.g. http://192.168.1.100)
      "RequestUri": "http://YOUR_INVERTER_LAN_IP",
      // Inverter local API request body — includes the inverter password and serial number.
      // Format: optType={REQUESTNAME}&pwd=YOUR_PASSWORD
      "RequestBody": "optType={REQUESTNAME}&pwd=YOUR_INVERTER_PASSWORD"
    },
    "OpenMeteoApiSettingsOptions": {
      // Latitude and longitude for your location (decimal degrees).
      "Latitude": 51.5,
      "Longitude": -0.1
    },
    "BatteryOptions": {
      // Total usable battery capacity in Wh.
      // Example: 5800 for one battery, 11600 for two.
      "CapacityInWh": 5800
    },
    "OctopusEnergyApiOptions": {
      // Octopus Energy API URL for your product and tariff.
      // Format: https://api.octopus.energy/v1/products/YOUR_PRODUCT_CODE/electricity-tariffs/YOUR_TARIFF_CODE
      "RequestUri": "https://api.octopus.energy/v1/products/YOUR_PRODUCT_CODE/electricity-tariffs/YOUR_TARIFF_CODE"
    }
  }
}
